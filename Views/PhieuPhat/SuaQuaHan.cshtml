@model CSDLNC.Models.SuaPhieuPhatQuaHanViewModel

@{
    ViewData["Title"] = "Sửa phiếu phạt quá hạn";
    var dsSach = ViewBag.DanhSachSach as List<CSDLNC.Models.SachGoiYViewModel> ?? new List<CSDLNC.Models.SachGoiYViewModel>();
}

<div class="container-fluid">
    <div class="card">
        <div class="card-body">

            <h3 class="card-title mb-3">Sửa phiếu phạt quá hạn</h3>

            @if (!string.IsNullOrEmpty(Model.ThongBao))
            {
                <div class="alert alert-danger">
                    @Model.ThongBao
                </div>
            }

            <form asp-controller="PhieuPhat" asp-action="SuaQuaHan" method="post">
                @Html.AntiForgeryToken()

                <input asp-for="SoPhieuPhatQuaHan" type="hidden" />

                <div class="row mb-4">
                    <div class="col-md-4">
                        <b>Số phiếu phạt:</b> @Model.SoPhieuPhatQuaHan
                    </div>

                    <div class="col-md-4">
                        <b>Ngày lập:</b> @Model.NgayLap.ToString("dd/MM/yyyy")
                    </div>

                    <div class="col-md-4">
                        <b>Số phiếu mượn:</b> @Model.SoPhieuMuonTra
                    </div>

                    <div class="col-md-4 mt-2">
                        <b>Mã sinh viên:</b> @Model.MaSinhVien
                    </div>

                    <div class="col-md-4 mt-2">
                        <b>Người lập:</b> @Model.TenNguoiDung
                    </div>

                    <div class="col-md-4 mt-2">
                        <b>Tổng phạt hiện tại:</b> @Model.TongPhat.ToString("N0")
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Ngày mượn</label>
                        <input asp-for="NgayMuon" type="date" class="form-control" readonly />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label">Hạn trả</label>
                        <input asp-for="HanTra" type="date" class="form-control" readonly />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label">Ngày trả</label>
                        <input asp-for="NgayTra" type="date" class="form-control" />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label">Mức phạt mỗi ngày</label>
                        <input asp-for="MucPhatMoiNgay"
                               type="number"
                               min="0"
                               class="form-control" />
                    </div>
                </div>

                <h5 class="mb-3">Danh sách sách quá hạn</h5>

                <table class="table table-bordered align-middle" id="bangSachQuaHan">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 60px;">STT</th>
                            <th>Mã sách</th>
                            <th style="width: 90px;">Xóa</th>
                        </tr>
                    </thead>

                    <tbody>
                        @for (int i = 0; i < Model.DanhSachChiTiet.Count; i++)
                        {
                            <tr>
                                <td class="stt">@(i + 1)</td>

                                <td>
                                    <div class="combo-box sach-combo">
                                        <input name="DanhSachChiTiet[@i].MaSach"
                                               value="@Model.DanhSachChiTiet[i].MaSach"
                                               class="form-control input-ma-sach"
                                               autocomplete="off"
                                               placeholder="Nhập hoặc chọn mã sách"
                                               oninput="locSach(this)"
                                               onclick="hienDanhSachSach(this)" />

                                        <div class="combo-list sach-list">
                                            @foreach (var sach in dsSach)
                                            {
                                                <div class="combo-item"
                                                     data-ma="@sach.MaSach"
                                                     data-ten="@sach.TenSach"
                                                     onclick="chonSach(this)">
                                                    <span class="combo-code">@sach.MaSach</span>
                                                    <span class="combo-name"> - @sach.TenSach</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <button type="button" class="btn btn-sm btn-danger" onclick="xoaDong(this)">
                                        Xóa
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <button type="button" class="btn btn-success mb-3" onclick="themDongSach()">
                    + Thêm sách
                </button>

                <br />

                <button type="submit" class="btn btn-primary">
                    Lưu thay đổi
                </button>

                <a asp-controller="PhieuPhat"
                   asp-action="ChiTietQuaHan"
                   asp-route-id="@Model.SoPhieuPhatQuaHan"
                   class="btn btn-info">
                    Xem chi tiết
                </a>

                <a asp-controller="PhieuPhat"
                   asp-action="LapQuaHan"
                   class="btn btn-secondary">
                    Quay lại danh sách
                </a>
            </form>

        </div>
    </div>
</div>

<style>
    .combo-box {
        position: relative;
        width: 100%;
    }

    .combo-list {
        display: none;
        position: absolute;
        top: 105%;
        left: 0;
        right: 0;
        z-index: 9999;
        background: #ffffff;
        border: 1px solid #d9e2ec;
        border-radius: 12px;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.15);
        max-height: 240px;
        overflow-y: auto;
        padding: 8px;
    }

    .combo-item {
        padding: 10px 12px;
        border-radius: 9px;
        cursor: pointer;
        font-size: 14px;
        color: #334155;
        transition: all 0.15s ease;
    }

        .combo-item:hover {
            background: #e8f3ff;
            color: #0d6efd;
            font-weight: 600;
        }

    .combo-code {
        display: inline-block;
        padding: 3px 8px;
        border-radius: 999px;
        background: #f1f5f9;
        color: #2563eb;
        font-weight: 600;
    }

    .combo-name {
        color: #64748b;
        margin-left: 4px;
    }

    .combo-item:hover .combo-code {
        background: #dbeafe;
    }

    .combo-item:hover .combo-name {
        color: #0d6efd;
    }
</style>

@section Scripts {
    <script>
        function hienDanhSachSach(input) {
            const combo = input.closest(".sach-combo");
            const danhSach = combo.querySelector(".sach-list");

            danhSach.style.display = "block";
            locSach(input);
        }

        function locSach(input) {
            const combo = input.closest(".sach-combo");
            const danhSach = combo.querySelector(".sach-list");
            const tuKhoa = input.value.toLowerCase();

            const items = combo.querySelectorAll(".sach-list .combo-item");

            let coKetQua = false;

            items.forEach(function (item) {
                const ma = item.dataset.ma.toLowerCase();
                const ten = item.dataset.ten.toLowerCase();
                const noiDung = ma + " " + ten;

                if (noiDung.includes(tuKhoa)) {
                    item.style.display = "block";
                    coKetQua = true;
                } else {
                    item.style.display = "none";
                }
            });

            danhSach.style.display = coKetQua ? "block" : "none";
        }

        function chonSach(item) {
            const combo = item.closest(".sach-combo");
            const input = combo.querySelector(".input-ma-sach");

            input.value = item.dataset.ma;
            combo.querySelector(".sach-list").style.display = "none";
        }

        document.addEventListener("click", function (event) {
            document.querySelectorAll(".combo-box").forEach(function (combo) {
                if (!combo.contains(event.target)) {
                    const list = combo.querySelector(".combo-list");
                    if (list) {
                        list.style.display = "none";
                    }
                }
            });
        });

        function capNhatSTT() {
            const rows = document.querySelectorAll("#bangSachQuaHan tbody tr");

            rows.forEach(function (row, index) {
                row.querySelector(".stt").innerText = index + 1;

                row.querySelectorAll("input").forEach(function (input) {
                    input.name = input.name.replace(/DanhSachChiTiet\[\d+\]/, "DanhSachChiTiet[" + index + "]");
                });
            });
        }

        function themDongSach() {
            const tbody = document.querySelector("#bangSachQuaHan tbody");
            const index = tbody.querySelectorAll("tr").length;

            const row = document.createElement("tr");

            row.innerHTML = `
                <td class="stt">${index + 1}</td>

                <td>
                    <div class="combo-box sach-combo">
                        <input name="DanhSachChiTiet[${index}].MaSach"
                               class="form-control input-ma-sach"
                               autocomplete="off"
                               placeholder="Nhập hoặc chọn mã sách"
                               oninput="locSach(this)"
                               onclick="hienDanhSachSach(this)" />

                        <div class="combo-list sach-list">
        @foreach (var sach in dsSach)
        {
                                    <div class="combo-item"
                                         data-ma="@sach.MaSach"
                                         data-ten="@sach.TenSach"
                                         onclick="chonSach(this)">
                                        <span class="combo-code">@sach.MaSach</span>
                                        <span class="combo-name"> - @sach.TenSach</span>
                                    </div>
        }
                        </div>
                    </div>
                </td>

                <td>
                    <button type="button" class="btn btn-sm btn-danger" onclick="xoaDong(this)">
                        Xóa
                    </button>
                </td>
            `;

            tbody.appendChild(row);
        }

        function xoaDong(button) {
            const tbody = document.querySelector("#bangSachQuaHan tbody");

            if (tbody.querySelectorAll("tr").length <= 1) {
                alert("Phải có ít nhất một dòng sách.");
                return;
            }

            button.closest("tr").remove();
            capNhatSTT();
        }
    </script>
}