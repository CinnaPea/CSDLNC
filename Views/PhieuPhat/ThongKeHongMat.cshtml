@model CSDLNC.Models.ThongKeSachHongMatViewModel

@{
    ViewData["Title"] = "Thống kê sách hỏng, mất trong tháng";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-body">

            <h3 class="card-title mb-3">Thống kê sách hỏng, mất trong tháng</h3>

            <

            @if (!string.IsNullOrEmpty(Model.ThongBao))
            {
                <div class="alert alert-danger">
                    @Model.ThongBao
                </div>
            }

            <form asp-controller="PhieuPhat"
                  asp-action="ThongKeHongMat"
                  method="post"
                  class="mb-4">

                @Html.AntiForgeryToken()

                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Tháng</label>
                        <input asp-for="Thang"
                               type="number"
                               min="1"
                               max="12"
                               class="form-control" />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label">Năm</label>
                        <input asp-for="Nam"
                               type="number"
                               min="2000"
                               class="form-control" />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label">Tình trạng</label>
                        <select asp-for="TinhTrang" class="form-select">
                            <option value="Tất cả">Tất cả</option>
                            <option value="Hỏng">Hỏng</option>
                            <option value="Mất">Mất</option>
                        </select>
                    </div>

                    <div class="col-md-3 mb-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary">
                            Thống kê
                        </button>
                    </div>
                </div>
            </form>

            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="border rounded p-3 bg-light">
                        <b>Tổng sách hỏng/mất</b>
                        <div class="fs-4">@Model.TongSoSachHongMat</div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border rounded p-3 bg-light">
                        <b>Sách hỏng</b>
                        <div class="fs-4">@Model.SoSachHong</div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border rounded p-3 bg-light">
                        <b>Sách mất</b>
                        <div class="fs-4">@Model.SoSachMat</div>
                    </div>
                </div>
            </div>

            <h5>Danh sách chi tiết</h5>

            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>STT</th>
                        <th>Mã sách</th>
                        <th>Tên sách</th>
                        <th>Thể loại</th>
                        <th>Tác giả</th>
                        <th>NXB</th>
                        <th>Tình trạng</th>
                    </tr>
                </thead>

                <tbody>
                    @{
                        int stt = 1;
                    }

                    @foreach (var item in Model.DanhSach)
                    {
                        <tr>
                            <td>@stt</td>
                            <td>@item.MaSach</td>
                            <td>@item.TenSach</td>
                            <td>@item.TheLoai</td>
                            <td>@item.TacGia</td>
                            <td>@item.NXB</td>
                            <td>@item.TinhTrang</td>
                        </tr>

                        stt++;
                    }

                    @if (Model.DanhSach.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">
                                Chưa có dữ liệu thống kê.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>