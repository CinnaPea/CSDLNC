@model CSDLNC.Models.Admin.UserCreateEditViewModel

@{
    ViewData["Title"] = "Thêm người dùng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/kiemke.css" asp-append-version="true" />
}

<div class="kho-dashboard">

    <!-- HEADER -->
    <div class="page-heading">
        <div>
            <h2>Thêm người dùng</h2>
            <p>Tạo tài khoản và phân quyền theo nhóm</p>
        </div>
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="row g-3">

        <!-- LEFT FORM -->
        <div class="col-lg-8">
            <div class="panel-card">

                <h5>Thông tin người dùng</h5>

                <div class="mb-3">
                    <label>Tên đăng nhập</label>
                    <input asp-for="Tendangnhap" class="form-control" />
                    <span asp-validation-for="Tendangnhap" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label>Họ tên</label>
                    <input asp-for="Tennguoidung" class="form-control" />
                    <span asp-validation-for="Tennguoidung" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label>Mật khẩu</label>
                    <input asp-for="Matkhau" type="password" class="form-control" />
                    <span asp-validation-for="Matkhau" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label>Nhóm quyền</label>
                    <select asp-for="SelectedGroups"
                            asp-items="Model.AvailableGroups"
                            multiple
                            class="form-control"
                            style="height: 160px;">
                    </select>
                    <span asp-validation-for="SelectedGroups" class="text-danger"></span>
                </div>

            </div>
        </div>

        <!-- RIGHT ACTION -->
        <div class="col-lg-4">

            <div class="panel-card">
                <h5>Thao tác</h5>

                <button type="submit" class="btn btn-filter-primary w-100 mb-2">
                    Tạo người dùng
                </button>

                <a asp-action="Index"
                   class="btn btn-filter-secondary w-100">
                    Quay lại
                </a>
            </div>

        </div>

    </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
