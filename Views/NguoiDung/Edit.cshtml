@model CSDLNC.Models.Admin.UserCreateEditViewModel

<div class="panel-card">
    <h4>Chỉnh sửa người dùng</h4>

    <form asp-action="Edit" method="post">

        <input type="hidden" asp-for="Manguoidung" />

        <!-- SAME FIELDS -->
        <!-- copy from Create -->

        <div class="row g-3">

            <div class="col-md-6">
                <label>Tên đăng nhập</label>
                <input asp-for="Tendangnhap" class="form-control" />
            </div>

            <div class="col-md-6">
                <label>Họ tên</label>
                <input asp-for="Tennguoidung" class="form-control" />
            </div>

            <div class="col-md-6">
                <label>Nhóm quyền</label>

                <select asp-for="SelectedGroups"
                        asp-items="Model.AvailableGroups"
                        multiple
                        class="form-select"
                        style="height: 140px;">
                </select>
            </div>

        </div>

        <div class="mt-3">
            <button class="btn btn-primary">Lưu thay đổi</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>

    </form>
</div>