@model CSDLNC.Models.Admin.NguoiDungIndexViewModel

@{
    ViewData["Title"] = "Quản lý người dùng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/kiemke.css" asp-append-version="true" />
}

<div class="panel-card">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Quản lý người dùng</h4>

        <a asp-action="Create" class="btn btn-success">
            + Thêm người dùng
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <!-- FILTER BAR -->
    <form method="get" class="row g-2 mb-3">

        <div class="col-md-5">
            <input name="keyword"
                   class="form-control"
                   value="@Model.Keyword"
                   placeholder="Tìm theo tên đăng nhập / họ tên..." />
        </div>

        <div class="col-md-4">
            <select name="group" class="form-select">
                <option value="">-- Tất cả nhóm --</option>
                @foreach (var group in Model.AvailableGroups)
                {
                    <option value="@group.Value" selected="@(group.Value == Model.Group)">
                        @group.Text
                    </option>
                }
            </select>
        </div>

        <div class="col-md-3 d-flex gap-2">
            <button class="btn btn-primary w-100">Lọc</button>
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
        </div>

    </form>

    <!-- TABLE -->
    <div class="table-responsive">
        <table class="table table-hover align-middle">

            <thead class="table-light">
                <tr>
                    <th>Mã</th>
                    <th>Tài khoản</th>
                    <th>Họ tên</th>
                    <th>Nhóm quyền</th>
                    <th width="180">Thao tác</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.Users.Any())
                {
                    foreach (var u in Model.Users)
                    {
                        <tr>
                            <td>@u.Manguoidung</td>
                            <td>@u.Tendangnhap</td>
                            <td>@u.Tennguoidung</td>

                            <!-- GROUP BADGES -->
                            <td>
                                @if (u.Manhoms != null && u.Manhoms.Any())
                                {
                                    foreach (var g in u.Manhoms)
                                    {
                                        <span class="badge bg-primary me-1">
                                            @g.Tennhom
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Chưa phân nhóm</span>
                                }
                            </td>

                            <!-- ACTIONS -->
                            <td class="d-flex gap-2">

                                <a asp-action="Edit"
                                   asp-route-id="@u.Manguoidung"
                                   class="btn btn-sm btn-outline-primary">
                                    Sửa
                                </a>

                                <form asp-action="Delete"
                                      asp-route-id="@u.Manguoidung"
                                      method="post"
                                      onsubmit="return confirm('Xac nhan xoa nguoi dung nay?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Xoa
                                    </button>
                                </form>

                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            Không có dữ liệu người dùng
                        </td>
                    </tr>
                }

            </tbody>

        </table>
    </div>

    @if (Model.TotalUsers > 0)
    {
        var firstItem = (Model.PageNumber - 1) * Model.PageSize + 1;
        var lastItem = Math.Min(Model.PageNumber * Model.PageSize, Model.TotalUsers);

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-3">
            <div class="text-muted small">
                Hiển thị @firstItem-@lastItem / @Model.TotalUsers người dùng
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Phân trang người dùng">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-keyword="@Model.Keyword"
                               asp-route-group="@Model.Group"
                               asp-route-page="@(Model.PageNumber - 1)">
                                Trước
                            </a>
                        </li>

                        @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                        {
                            <li class="page-item @(pageNumber == Model.PageNumber ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-keyword="@Model.Keyword"
                                   asp-route-group="@Model.Group"
                                   asp-route-page="@pageNumber">
                                    @pageNumber
                                </a>
                            </li>
                        }

                        <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-keyword="@Model.Keyword"
                               asp-route-group="@Model.Group"
                               asp-route-page="@(Model.PageNumber + 1)">
                                Sau
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    }
</div>
