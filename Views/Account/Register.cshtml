@model CSDLNC.Models.RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký";
    Layout = "_Layout";
}

<div class="auth-container">
    <div class="auth-card">
        <h2>Đăng ký</h2>
        <p>Tài khoản mới sẽ được cấp quyền xem dữ liệu</p>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="TenNguoiDung" class="form-label">Họ tên</label>
                <input asp-for="TenNguoiDung" class="form-control" />
                <span asp-validation-for="TenNguoiDung" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TenDangNhap" class="form-label">Tên đăng nhập</label>
                <input asp-for="TenDangNhap" class="form-control" />
                <span asp-validation-for="TenDangNhap" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MatKhau" class="form-label">Mật khẩu</label>
                <input asp-for="MatKhau" type="password" class="form-control" />
                <span asp-validation-for="MatKhau" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="XacNhanMatKhau" class="form-label">Xác nhận mật khẩu</label>
                <input asp-for="XacNhanMatKhau" type="password" class="form-control" />
                <span asp-validation-for="XacNhanMatKhau" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Đăng ký</button>

            <div class="auth-link">
                Đã có tài khoản?
                <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
            </div>
        </form>
    </div>
</div>