@model ThongKeViPhamMuonTraViewModel

@{
    ViewData["Title"] = "Thống kê vi phạm mượn trả";
    var maxLoaiViPham = Math.Max(1, Model.PhanBoLoaiViPham.Select(x => x.Value).DefaultIfEmpty(0).Max());
    var maxDocGia = Math.Max(1, Model.TopDocGiaViPham.Select(x => x.Value).DefaultIfEmpty(0).Max());
}

@section Styles {
    <link rel="stylesheet" href="~/css/phuc-workflows.css" asp-append-version="true" />
}

<div class="container-fluid workflow-shell borrow-page">
    <div class="borrow-titlebar no-print">
        <a asp-controller="Home" asp-action="Index" class="borrow-back" title="Quay lại dashboard">
            <iconify-icon icon="solar:arrow-left-linear"></iconify-icon>
        </a>
        <div>
            <h1>Thống kê vi phạm mượn trả</h1>
            <p>Tổng hợp vi phạm theo độc giả, gồm quá hạn và các phiếu phạt hỏng/mất liên quan đến mượn trả.</p>
        </div>
    </div>

    <form asp-action="Index" method="get" class="borrow-form-section no-print">
        <div class="row g-3 align-items-end">
            <div class="col-md-2">
                <label asp-for="Thang" class="form-label">Tháng</label>
                <input asp-for="Thang" type="number" min="1" max="12" class="form-control" />
                <span asp-validation-for="Thang" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="Nam" class="form-label">Năm</label>
                <input asp-for="Nam" type="number" min="2000" max="2100" class="form-control" />
                <span asp-validation-for="Nam" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="LoaiViPham" class="form-label">Loại vi phạm</label>
                <select asp-for="LoaiViPham" class="form-select">
                    <option value="Tất cả">Tất cả</option>
                    <option value="Quá hạn">Quá hạn</option>
                    <option value="Hỏng/Mất">Hỏng/Mất</option>
                </select>
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-primary">Thống kê</button>
            </div>
            <div class="col-md-auto">
                <button type="button" class="btn btn-outline-secondary" onclick="window.print()">
                    <iconify-icon icon="solar:printer-2-line-duotone"></iconify-icon>
                    In mẫu biểu
                </button>
            </div>
        </div>
    </form>

    <div class="report-context-note no-print">
        Báo cáo này khác với “Thống kê sách hỏng/mất trong tháng”: màn này nhìn theo người đọc và hành vi vi phạm,
        còn báo cáo hỏng/mất nhìn theo tình trạng bản sách trong kho.
    </div>

    <div class="row g-3 mb-4 no-print">
        <div class="col-md-3">
            <div class="metric-card metric-blue">
                <div class="metric-label">Tổng vi phạm</div>
                <div class="metric-value">@Model.TongViPham</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card metric-amber">
                <div class="metric-label">Quá hạn</div>
                <div class="metric-value">@Model.ViPhamQuaHan</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card metric-red">
                <div class="metric-label">Hỏng/Mất</div>
                <div class="metric-value">@Model.ViPhamHongMat</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card metric-green">
                <div class="metric-label">Độc giả vi phạm</div>
                <div class="metric-value">@Model.SoDocGiaViPham</div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4 no-print">
        <div class="col-lg-5">
            <section class="dashboard-panel h-100">
                <div class="dashboard-panel-header">
                    <h2>Phân bố loại vi phạm</h2>
                    <span>@Model.Thang/@Model.Nam</span>
                </div>

                <div class="chart-list">
                    @foreach (var item in Model.PhanBoLoaiViPham)
                    {
                        var percent = item.Value * 100 / maxLoaiViPham;
                        <div class="chart-row">
                            <div class="chart-row-label">
                                <span>@item.Label</span>
                                <strong>@item.Value</strong>
                            </div>
                            <div class="chart-track">
                                <div class="chart-fill @(item.Label.Contains("Hỏng") ? "chart-red" : "chart-amber")" style="width: @percent%"></div>
                            </div>
                        </div>
                    }
                </div>

                <div class="dashboard-note">
                    Tổng tiền phạt ghi nhận: <strong>@Model.TongTienPhat.ToString("N0") đồng</strong>
                </div>
            </section>
        </div>

        <div class="col-lg-7">
            <section class="dashboard-panel h-100">
                <div class="dashboard-panel-header">
                    <h2>Top độc giả vi phạm</h2>
                    <span>Tối đa 5 người</span>
                </div>

                <div class="chart-list">
                    @if (Model.TopDocGiaViPham.Any())
                    {
                        @foreach (var item in Model.TopDocGiaViPham)
                        {
                            var percent = item.Value * 100 / maxDocGia;
                            <div class="chart-row">
                                <div class="chart-row-label">
                                    <span>@item.Label</span>
                                    <strong>@item.Value lần</strong>
                                </div>
                                <div class="chart-track">
                                    <div class="chart-fill chart-blue" style="width: @percent%"></div>
                                </div>
                                <div class="text-muted small">@item.Amount.ToString("N0") đồng</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-row-message">Không có dữ liệu để vẽ biểu đồ.</div>
                    }
                </div>
            </section>
        </div>
    </div>

    <section class="borrow-board no-print">
        <div class="borrow-board-header">
            <h2>Kết quả thống kê</h2>
        </div>

        <div class="table-responsive">
            <table class="table borrow-table align-middle">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 60px;">STT</th>
                        <th>Mã độc giả</th>
                        <th>Họ tên</th>
                        <th>Loại vi phạm</th>
                        <th>Mức độ</th>
                        <th>Hình thức xử lý</th>
                        <th>Ghi chú</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.KetQua.Any())
                    {
                        @for (var i = 0; i < Model.KetQua.Count; i++)
                        {
                            var item = Model.KetQua[i];
                            <tr>
                                <td class="text-center">@(i + 1)</td>
                                <td class="fw-semibold">@item.MaSinhVien</td>
                                <td>@item.HoTen</td>
                                <td>@item.LoaiViPham</td>
                                <td>@item.MucDoViPham</td>
                                <td>@item.HinhThucXuLy</td>
                                <td>@item.GhiChu</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">Không có dữ liệu</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="mb-sheet violation-mb-sheet print-only">
        <div class="mb-topline">
            <strong>THƯ VIỆN ĐẠI HỌC X</strong>
            <strong>Số phiếu: ...........</strong>
        </div>

        <h2>THỐNG KÊ VI PHẠM MƯỢN TRẢ SÁCH THÁNG @Model.Thang</h2>

        <table class="mb-table violation-mb-table">
            <thead>
                <tr>
                    <th>STT</th>
                    <th>Mã độc giả</th>
                    <th>Họ và tên</th>
                    <th>Loại vi phạm</th>
                    <th>Mức độ vi phạm</th>
                    <th>Hình thức xử lý</th>
                    <th>Ghi chú</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.KetQua.Any())
                {
                    @for (var i = 0; i < Model.KetQua.Count; i++)
                    {
                        var item = Model.KetQua[i];
                        <tr>
                            <td class="text-center">@(i + 1)</td>
                            <td>@item.MaSinhVien</td>
                            <td>@item.HoTen</td>
                            <td>@item.LoaiViPham</td>
                            <td>@item.MucDoViPham</td>
                            <td>@item.HinhThucXuLy</td>
                            <td>@item.GhiChu</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td class="text-center">&nbsp;</td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mb-date-sign">Ngày ..... tháng ..... năm .....</div>
        <div class="mb-signatures">
            <strong>Người thống kê</strong>
            <strong>Quản lý thư viện</strong>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
