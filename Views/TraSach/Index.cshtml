@model TraSachIndexViewModel

@{
    ViewData["Title"] = "Cập nhật trả sách";
    var first = Model.ChiTiet.FirstOrDefault();
    var fromDate = Model.TuNgay?.ToString("yyyy-MM-dd");
    var toDate = Model.DenNgay?.ToString("yyyy-MM-dd");
}

@section Styles {
    <link rel="stylesheet" href="~/css/phuc-workflows.css" asp-append-version="true" />
}

<div class="container-fluid workflow-shell borrow-page">
    <div class="borrow-titlebar">
        <a asp-controller="Home" asp-action="Index" class="borrow-back" title="Quay lại dashboard">
            <iconify-icon icon="solar:arrow-left-linear"></iconify-icon>
        </a>
        <div>
            <h1>Cập nhật trả sách</h1>
            <p>Chọn phiếu còn sách chưa trả, xác nhận ngày trả và đưa sách đủ điều kiện về kho.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (TempData["InfoMessage"] is string infoMessage)
    {
        <div class="alert alert-info">@infoMessage</div>
    }

    <section class="borrow-form-section">
        <form asp-action="Index" method="get">
            <div class="filter-grid">
                <div class="borrow-search">
                    <iconify-icon icon="solar:magnifer-linear"></iconify-icon>
                    <input name="TuKhoa"
                           value="@Model.TuKhoa"
                           placeholder="Số phiếu, mã sinh viên hoặc tên sinh viên" />
                </div>

                <select name="SoPhieuMuon" asp-items="Model.PhieuMuonOptions" class="form-select">
                    <option value="">-- Chọn phiếu còn sách chưa trả --</option>
                </select>

                <select name="TrangThaiHan" class="form-select">
                    <option value="TatCa" selected="@(Model.TrangThaiHan == "TatCa")">Tất cả hạn trả</option>
                    <option value="ConHan" selected="@(Model.TrangThaiHan == "ConHan")">Còn hạn</option>
                    <option value="QuaHan" selected="@(Model.TrangThaiHan == "QuaHan")">Quá hạn</option>
                </select>

                <input name="TuNgay" value="@fromDate" type="date" class="form-control" title="Hạn trả từ" />
                <input name="DenNgay" value="@toDate" type="date" class="form-control" title="Hạn trả đến" />

                <select name="PageSize" class="form-select">
                    <option value="8" selected="@(Model.PageSize == 8)">8 dòng</option>
                    <option value="15" selected="@(Model.PageSize == 15)">15 dòng</option>
                    <option value="30" selected="@(Model.PageSize == 30)">30 dòng</option>
                </select>

                <button type="submit" class="btn btn-primary">
                    <iconify-icon icon="solar:filter-line-duotone"></iconify-icon>
                    Lọc / Xem phiếu
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    <iconify-icon icon="solar:restart-linear"></iconify-icon>
                    Làm mới
                </a>
            </div>
        </form>
    </section>

    <div class="row g-4 mb-4">
        <div class="col-lg-5">
            <section class="selection-panel h-100">
                <h2 class="h6 mb-3">Phiếu còn sách chưa trả</h2>
                <div class="table-responsive">
                    <table class="table table-sm compact-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Số phiếu</th>
                                <th>Sinh viên</th>
                                <th>Hạn trả</th>
                                <th class="text-center">Chưa trả</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.PhieuMuonCanTra)
                            {
                                var overdue = item.HanTra < DateOnly.FromDateTime(DateTime.Today);
                                <tr>
                                    <td>
                                        <a asp-action="Index"
                                           asp-route-SoPhieuMuon="@item.SoPhieuMuon"
                                           asp-route-TuKhoa="@Model.TuKhoa"
                                           asp-route-TrangThaiHan="@Model.TrangThaiHan"
                                           asp-route-TuNgay="@fromDate"
                                           asp-route-DenNgay="@toDate"
                                           asp-route-Page="@Model.Page"
                                           asp-route-PageSize="@Model.PageSize"
                                           class="fw-semibold">@item.SoPhieuMuon</a>
                                    </td>
                                    <td>
                                        <div>@item.MaSinhVien - @item.HoTen</div>
                                        <div class="text-muted small">@item.NgayMuon.ToString("dd/MM/yyyy")</div>
                                    </td>
                                    <td>
                                        <span class="@(overdue ? "text-danger fw-semibold" : "")">@item.HanTra.ToString("dd/MM/yyyy")</span>
                                    </td>
                                    <td class="text-center">@item.SoSachChuaTra</td>
                                </tr>
                            }
                            @if (!Model.PhieuMuonCanTra.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-muted">Không có phiếu cần trả phù hợp</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="pagination-bar compact-pagination">
                    <div class="text-muted">Trang @Model.Page / @Model.TotalPages</div>
                    <div class="pagination-actions">
                        <a asp-action="Index"
                           asp-route-SoPhieuMuon="@Model.SoPhieuMuon"
                           asp-route-TuKhoa="@Model.TuKhoa"
                           asp-route-TrangThaiHan="@Model.TrangThaiHan"
                           asp-route-TuNgay="@fromDate"
                           asp-route-DenNgay="@toDate"
                           asp-route-PageSize="@Model.PageSize"
                           asp-route-Page="@(Model.Page - 1)"
                           class="btn btn-outline-secondary btn-sm @(Model.HasPreviousPage ? "" : "disabled")">
                            Trước
                        </a>
                        <a asp-action="Index"
                           asp-route-SoPhieuMuon="@Model.SoPhieuMuon"
                           asp-route-TuKhoa="@Model.TuKhoa"
                           asp-route-TrangThaiHan="@Model.TrangThaiHan"
                           asp-route-TuNgay="@fromDate"
                           asp-route-DenNgay="@toDate"
                           asp-route-PageSize="@Model.PageSize"
                           asp-route-Page="@(Model.Page + 1)"
                           class="btn btn-outline-secondary btn-sm @(Model.HasNextPage ? "" : "disabled")">
                            Sau
                        </a>
                    </div>
                </div>
            </section>
        </div>

        <div class="col-lg-7">
            @if (first != null)
            {
                <section class="selection-panel h-100">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <div class="text-muted small">Số phiếu</div>
                            <div class="fw-semibold">@first.SoPhieuMuon</div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-muted small">Sinh viên</div>
                            <div class="fw-semibold">@first.MaSinhVien - @first.HoTen</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted small">Ngày mượn</div>
                            <div class="fw-semibold">@first.NgayMuon.ToString("dd/MM/yyyy")</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted small">Hạn trả</div>
                            <div class="fw-semibold">@first.HanTra.ToString("dd/MM/yyyy")</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted small">Trạng thái</div>
                            <div class="fw-semibold">@first.TrangThaiPhieu</div>
                        </div>
                    </div>
                </section>
            }
            else
            {
                <section class="selection-panel h-100 d-flex align-items-center justify-content-center text-muted">
                    Chọn một phiếu còn sách chưa trả để cập nhật.
                </section>
            }
        </div>
    </div>

    @if (first != null)
    {
        <div class="table-responsive bg-white border rounded">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Mã sách</th>
                        <th>Tên sách</th>
                        <th>Tình trạng</th>
                        <th>Ngày trả</th>
                        <th style="width: 420px;">Cập nhật</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ChiTiet)
                    {
                        var returned = item.NgayTra.HasValue;
                        var overdue = first.HanTra.Date < DateTime.Today;
                        <tr>
                            <td class="fw-semibold">@item.MaSach</td>
                            <td>
                                <div>@item.TenSach</div>
                                <div class="text-muted small">@item.TheLoai - @item.TacGia</div>
                            </td>
                            <td>@item.TinhTrang</td>
                            <td>@(item.NgayTra?.ToString("dd/MM/yyyy") ?? "Chưa trả")</td>
                            <td>
                                @if (returned)
                                {
                                    <span class="badge bg-success">Đã trả</span>
                                }
                                else if (overdue)
                                {
                                    <div class="return-route-note mb-2">
                                        Phiếu này đã quá hạn. Không cập nhật trả thường tại đây; hãy lập phiếu phạt quá hạn.
                                    </div>
                                    <div class="return-actions">
                                        <a asp-controller="PhieuPhat"
                                           asp-action="TaoQuaHan"
                                           class="btn btn-outline-danger btn-sm">
                                            <iconify-icon icon="solar:bill-list-line-duotone"></iconify-icon>
                                            Lập phiếu phạt quá hạn
                                        </a>
                                        <a asp-controller="PhieuPhat"
                                           asp-action="TaoHongMat"
                                           class="btn btn-outline-secondary btn-sm">
                                            <iconify-icon icon="solar:danger-triangle-line-duotone"></iconify-icon>
                                            Hỏng/Mất
                                        </a>
                                    </div>
                                }
                                else
                                {
                                    <form asp-action="CapNhat" method="post" class="row g-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="SoPhieuMuon" value="@item.SoPhieuMuon" />
                                        <input type="hidden" name="MaSach" value="@item.MaSach" />
                                        <input type="hidden" name="TinhTrangSauTra" value="Tốt" />

                                        <div class="col-4">
                                            <input type="date"
                                                   name="NgayTra"
                                                   value="@DateTime.Today.ToString("yyyy-MM-dd")"
                                                   class="form-control form-control-sm" />
                                        </div>
                                        <div class="col-3">
                                            <span class="return-mode-chip">Trả bình thường</span>
                                        </div>
                                        <div class="col-3">
                                            <input name="GhiChu" class="form-control form-control-sm" maxlength="255" placeholder="Ghi chú" />
                                        </div>
                                        <div class="col-2 d-grid">
                                            <button type="submit" class="btn btn-primary btn-sm">Lưu</button>
                                        </div>
                                        <div class="col-12">
                                            <div class="return-route-note">
                                                Nếu sách hỏng hoặc mất, không lưu ở dòng này. Chuyển sang màn lập phiếu phạt hỏng/mất để đúng luồng dữ liệu.
                                            </div>
                                            <div class="return-actions mt-2">
                                                <a asp-controller="PhieuPhat"
                                                   asp-action="TaoHongMat"
                                                   class="btn btn-outline-secondary btn-sm">
                                                    <iconify-icon icon="solar:danger-triangle-line-duotone"></iconify-icon>
                                                    Lập phiếu phạt hỏng/mất
                                                </a>
                                            </div>
                                        </div>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
